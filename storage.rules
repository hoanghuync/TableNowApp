rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() { return request.auth != null; }
    match /menu_items/{fileName} {
      allow read: if true;
      allow write: if signedIn();
    }
    match /avatars/{userId}/{fileName} {
      allow read: if true;
      allow write: if signedIn() && request.auth.uid == userId;
    }
  }
}
